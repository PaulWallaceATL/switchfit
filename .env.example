# Supabase — optional. The app runs fully without these (auth is bypassed for now).
# Create a project at https://supabase.com, then copy these from
# Project Settings -> API. Add the same keys in Vercel (Project -> Settings ->
# Environment Variables) for Production, Preview, and Development.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only. NEVER prefix with NEXT_PUBLIC. Used for trusted scan writes while
# auth is bypassed. Keep this secret; set it in Vercel as an (unexposed) env var.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
